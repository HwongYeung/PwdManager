<!--password-list.wxml-->
<view class="container">
  <!-- 顶部操作栏 -->
  <view class="header-actions">
    <view class="action-btn" bindtap="toggleSearch">
      <t-icon name="search" size="24px" color="#1976D2"></t-icon>
    </view>
    <view class="action-btn" bindtap="goToSettings">
      <t-icon name="setting" size="24px" color="#1976D2"></t-icon>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar {{showSearch ? 'show' : ''}}">
    <t-search
      value="{{searchValue}}"
      placeholder="搜索网站或用户名"
      bind:change="onSearchInput"
    ></t-search>
  </view>

  <!-- 密码列表 -->
  <scroll-view class="password-list" scroll-y>
    <view wx:if="{{passwords.length === 0}}" class="empty-state">
      <view class="empty-icon">🔒</view>
      <view class="empty-title">暂无密码</view>
      <view class="empty-desc">点击下方按钮添加第一个密码</view>
    </view>

    <view wx:else>
      <view 
        wx:for="{{passwords}}" 
        wx:key="id"
        class="password-item"
        data-id="{{item.id}}"
        bindtap="goToDetail"
      >
        <view class="item-icon">
          <view class="icon-placeholder">{{item.title.charAt(0).toUpperCase()}}</view>
        </view>
        <view class="item-content">
          <view class="item-title">{{item.title}}</view>
          <view class="item-username">{{item.username}}</view>
        </view>
        <view class="item-arrow">
          <t-icon name="chevron-right" size="20px" color="#ccc"></t-icon>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 添加按钮 -->
  <view class="fab-container">
    <t-fab
      icon="add"
      bind:click="addPassword"
    ></t-fab>
  </view>
</view>