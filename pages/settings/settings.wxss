/* settings.wxss */
.container {
  height: 100vh;
  background-color: #f5f5f5;
}

.settings-content {
  height: 100%;
  padding: 20rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding: 0 20rpx;
}

.security-notice {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.notice-icon {
  font-size: 48rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.notice-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.notice-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.notice-content text {
  display: block;
  margin-bottom: 8rpx;
}