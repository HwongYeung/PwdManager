<!--password-detail.wxml-->
<view class="container">
  <view wx:if="{{password}}" class="detail-content">
    <!-- 头部信息 -->
    <view class="header-card">
      <view class="site-icon">
        {{password.title.charAt(0).toUpperCase()}}
      </view>
      <view class="site-info">
        <view class="site-title">{{password.title}}</view>
        <view wx:if="{{password.url}}" class="site-url" bindtap="openUrl">
          {{password.url}}
        </view>
      </view>
    </view>

    <!-- 详细信息 -->
    <view class="info-section">
      <!-- 用户名 -->
      <t-cell-group>
        <t-cell
          title="用户名"
          description="{{password.username}}"
          right-icon="copy"
          data-type="username"
          bind:click="copyToClipboard"
        />
        
        <!-- 密码 -->
        <t-cell
          title="密码"
          description="{{showPassword ? password.password : '••••••••'}}"
          right-icon="copy"
          data-type="password"
          bind:click="copyToClipboard"
        >
          <view slot="note" class="password-actions">
            <view 
              class="action-btn"
              bindtap="togglePasswordVisibility"
            >
              <t-icon 
                name="{{showPassword ? 'browse-off' : 'browse'}}" 
                size="20px" 
                color="#1976D2"
              ></t-icon>
            </view>
          </view>
        </t-cell>

        <!-- 网址 -->
        <t-cell
          wx:if="{{password.url}}"
          title="网址"
          description="{{password.url}}"
          right-icon="copy"
          data-type="url"
          bind:click="copyToClipboard"
        />
      </t-cell-group>
    </view>

    <!-- 备注 -->
    <view wx:if="{{password.notes}}" class="notes-section">
      <view class="section-title">备注</view>
      <view class="notes-content">{{password.notes}}</view>
    </view>

    <!-- 时间信息 -->
    <view class="time-section">
      <view class="time-item">
        <text class="time-label">创建时间</text>
        <text class="time-value">{{password.created_at}}</text>
      </view>
      <view wx:if="{{password.updated_at !== password.created_at}}" class="time-item">
        <text class="time-label">更新时间</text>
        <text class="time-value">{{password.updated_at}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <t-button 
        theme="primary" 
        size="large"
        bind:tap="editPassword"
      >
        编辑
      </t-button>
      <t-button 
        theme="danger" 
        variant="outline"
        size="large"
        bind:tap="deletePassword"
      >
        删除
      </t-button>
    </view>
  </view>

  <view wx:else class="loading">
    <text>加载中...</text>
  </view>
</view>