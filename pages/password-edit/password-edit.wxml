<!--password-edit.wxml-->
<view class="container">
  <scroll-view class="form-container" scroll-y>
    <!-- 表单 -->
    <view class="form-section">
      <view class="section-title">{{isEdit ? '编辑密码' : '添加密码'}}</view>
      
      <view class="form-group">
        <t-input
          label="网站名称"
          placeholder="请输入网站名称"
          value="{{formData.title}}"
          data-field="title"
          bind:change="onInput"
          required
        />
      </view>
      
      <view class="form-group">
        <t-input
          label="网站地址"
          placeholder="请输入网站地址（可选）"
          value="{{formData.url}}"
          data-field="url"
          bind:change="onInput"
        />
      </view>
      
      <view class="form-group">
        <t-input
          label="用户名"
          placeholder="请输入用户名或邮箱"
          value="{{formData.username}}"
          data-field="username"
          bind:change="onInput"
          required
        />
      </view>
      
      <view class="form-group password-group">
        <t-input
          label="密码"
          placeholder="请输入密码"
          value="{{formData.password}}"
          type="{{showPassword ? 'text' : 'password'}}"
          data-field="password"
          bind:change="onInput"
          required
        />
        <view class="password-actions">
          <view 
            class="action-btn"
            bindtap="togglePasswordVisibility"
          >
            <t-icon 
              name="{{showPassword ? 'browse-off' : 'browse'}}" 
              size="20px" 
              color="#1976D2"
            ></t-icon>
          </view>
          <view 
            class="action-btn"
            bindtap="showPasswordGenerator"
          >
            <t-icon name="refresh" size="20px" color="#1976D2"></t-icon>
          </view>
        </view>
      </view>
      
      <view class="form-group">
        <view class="textarea-label">备注</view>
        <textarea
          class="textarea-input"
          placeholder="请输入备注信息（可选）"
          value="{{formData.notes}}"
          data-field="notes"
          bind:input="onInput"
          maxlength="200"
        ></textarea>
      </view>
    </view>
  </scroll-view>

  <!-- 保存按钮 -->
  <view class="save-button">
    <t-button 
      theme="primary" 
      size="large"
      bind:tap="savePassword"
    >
      {{isEdit ? '更新' : '保存'}}
    </t-button>
  </view>

  <!-- 密码生成器弹窗 -->
  <view wx:if="{{showPasswordGenerator}}" class="generator-overlay" bindtap="hidePasswordGenerator">
    <view class="generator-popup" catchtap="">
      <view class="generator-header">
        <view class="generator-title">密码生成器</view>
        <view class="close-btn" bindtap="hidePasswordGenerator">
          <t-icon name="close" size="24px" color="#666"></t-icon>
        </view>
      </view>
      
      <view class="generator-content">
        <view class="option-group">
          <view class="option-label">密码长度: {{generatorOptions.length}}</view>
          <slider
            min="6"
            max="32"
            value="{{generatorOptions.length}}"
            data-option="length"
            bind:change="onGeneratorOptionChange"
            activeColor="#1976D2"
          />
        </view>
        
        <view class="option-group">
          <checkbox-group data-option="includeUppercase" bind:change="onGeneratorOptionChange">
            <label class="checkbox-option">
              <checkbox
                checked="{{generatorOptions.includeUppercase}}"
                value="includeUppercase"
              />
              <text>包含大写字母 (A-Z)</text>
            </label>
          </checkbox-group>
        </view>
        
        <view class="option-group">
          <checkbox-group data-option="includeLowercase" bind:change="onGeneratorOptionChange">
            <label class="checkbox-option">
              <checkbox
                checked="{{generatorOptions.includeLowercase}}"
                value="includeLowercase"
              />
              <text>包含小写字母 (a-z)</text>
            </label>
          </checkbox-group>
        </view>
        
        <view class="option-group">
          <checkbox-group data-option="includeNumbers" bind:change="onGeneratorOptionChange">
            <label class="checkbox-option">
              <checkbox
                checked="{{generatorOptions.includeNumbers}}"
                value="includeNumbers"
              />
              <text>包含数字 (0-9)</text>
            </label>
          </checkbox-group>
        </view>
        
        <view class="option-group">
          <checkbox-group data-option="includeSymbols" bind:change="onGeneratorOptionChange">
            <label class="checkbox-option">
              <checkbox
                checked="{{generatorOptions.includeSymbols}}"
                value="includeSymbols"
              />
              <text>包含符号 (!@#$%^&*)</text>
            </label>
          </checkbox-group>
        </view>
      </view>
      
      <view class="generator-footer">
        <t-button 
          theme="primary" 
          size="large"
          bind:tap="generatePassword"
        >
          生成密码
        </t-button>
      </view>
    </view>
  </view>
</view>