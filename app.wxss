/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

/* 全局样式 */
.container {
  padding: 0;
  margin: 0;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #1976D2;
  color: white;
  border-radius: 8rpx;
  border: none;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary:active {
  background-color: #1565C0;
}

.btn-secondary {
  background-color: transparent;
  color: #1976D2;
  border: 2rpx solid #1976D2;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-secondary:active {
  background-color: rgba(25, 118, 210, 0.1);
}

/* 通用卡片样式 */
.card {
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin: 20rpx;
  overflow: hidden;
}

.card-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-body {
  padding: 32rpx;
}

.card-footer {
  padding: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #fafafa;
}

/* 通用文本样式 */
.text-primary {
  color: #1976D2;
}

.text-secondary {
  color: #666;
}

.text-muted {
  color: #999;
}

.text-danger {
  color: #f44336;
}

.text-success {
  color: #4caf50;
}

/* 通用间距 */
.mt-small { margin-top: 20rpx; }
.mt-medium { margin-top: 40rpx; }
.mt-large { margin-top: 60rpx; }

.mb-small { margin-bottom: 20rpx; }
.mb-medium { margin-bottom: 40rpx; }
.mb-large { margin-bottom: 60rpx; }

.p-small { padding: 20rpx; }
.p-medium { padding: 40rpx; }
.p-large { padding: 60rpx; }

/* 通用布局 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  align-items: center;
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* 通用边框 */
.border-bottom {
  border-bottom: 1rpx solid #f0f0f0;
}

.border-top {
  border-top: 1rpx solid #f0f0f0;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}